            background-color: #252D40;
            color: white;
            border: 1px solid #2A3244;
            border-radius: 10px;
            padding: 10px 14px;
            font-size: 13px;
            font-family: &quot;Segoe UI&quot;;
        }

        QLineEdit:focus {
            border: 1px solid #4F8EF7;
        }

        QPushButton#registerBtn {
            background-color: #4F8EF7;
            color: white;
            border: none;
            border-radius: 10px;
            padding: 12px;
            font-size: 14px;
            font-weight: bold;
            font-family: &quot;Segoe UI&quot;;
        }

        QPushButton#registerBtn:hover {
            background-color: #3A7BD5;
        }

        QPushButton#registerBtn:pressed {
            background-color: #2E6BC4;
        }

        QPushButton#loginRedirectBtn {
            background: transparent;
            color: #4F8EF7;
            border: none;
            font-size: 12px;
            font-family: &quot;Segoe UI&quot;;
        }

        QPushButton#loginRedirectBtn:hover {
            color: #7DB2FF;
        }

        QCheckBox {
            color: #C0C8D8;
            font-size: 12px;
            font-family: &quot;Segoe UI&quot;;
        }

        </string>
